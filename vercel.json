{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/mama/:slug", "destination": "/memoria-mama.html" },
    { "source": "/", "destination": "/dashboard.html" },
    { "source": "/:slug", "destination": "/memoria-pareja.html" }
  ]
}
